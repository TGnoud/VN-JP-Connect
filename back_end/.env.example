# Copy this file to .env for local development.
DB_TARGET=local
PORT=3001
CORS_ORIGINS=http://localhost:3000,https://vn-jp-connect.vercel.app

# Local runtime, migration, and seed (`npm run seed`).
MONGO_LOCAL_URI=mongodb://localhost:27017/vn_jp_connect_local
MONGO_LOCAL_DATABASE_NAME=vn_jp_connect_local

# Shared Atlas runtime, migration, and seed.
# Use only when DB_TARGET=atlas, `npm run db:migrate:atlas`, or `npm run seed:atlas`.
MONGO_ATLAS_URI=mongodb+srv://<db_username>:<db_password>@vn-jp-connect.eraedra.mongodb.net/?appName=VN-JP-CONNECT
MONGO_URI=mongodb+srv://<db_username>:<db_password>@vn-jp-connect.eraedra.mongodb.net/?appName=VN-JP-CONNECT
MONGO_ATLAS_DATABASE_NAME=vn_jp_connect

# Cloudinary profile image uploads. When unset, backend falls back to local uploads for dev.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Password reset OTP (PostgreSQL + Prisma) + mail ---
PASSWORD_RESET_DATABASE_URL=postgresql://postgres:123456@localhost:5432/vn_jp_password_reset?schema=public
# ≥32 chars in production. Dev may use openssl rand -hex 32.
PASSWORD_RESET_SECRET=acb9cc068f32d26e69b199d690492d7553e86626401b7954dae2d1911dbc018c
# Local test without sending mail: OTP is printed in the Nest terminal.
# Omit or set resend after configuring Resend (verified sender domain/API key).
PASSWORD_RESET_MAIL_MODE=log
# Resend (only used when PASSWORD_RESET_MAIL_MODE is not log)
RESEND_API_KEY=re_hvwWdKHJ_LLR7MwqffpW9nwN4e8rnFtVM
# Must be from a verified domain on Resend, or use onboarding@resend.dev only for sandbox tests.
RESEND_FROM_EMAIL="VN-JP Connect <onboarding@resend.dev>"
# Dev-only smoke test: POST /dev/test-email (403 when NODE_ENV=production).