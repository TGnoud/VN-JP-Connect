# Copy this file to .env for local development.
DB_TARGET=local
PORT=3001

# Local runtime, migration, and seed.
MONGO_LOCAL_URI=mongodb://localhost:27017/vn_jp_connect_local
MONGO_LOCAL_DATABASE_NAME=vn_jp_connect_local

# Shared Atlas runtime and migration. Use only when DB_TARGET=atlas or npm run db:migrate:atlas.
MONGO_URI=mongodb+srv://<db_username>:<db_password>@vn-jp-connect.eraedra.mongodb.net/?appName=VN-JP-CONNECT
MONGO_ATLAS_DATABASE_NAME=vn_jp_connect
